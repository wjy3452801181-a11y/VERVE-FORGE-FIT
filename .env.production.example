# VerveForge 生产环境变量
# 用于 TestFlight / App Store 发布构建
# 请将此文件复制为 .env.production 并填入真实值

# Supabase — 云端生产实例
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-production-anon-key

# 高德地图
AMAP_IOS_KEY=your-production-amap-ios-key
AMAP_ANDROID_KEY=your-production-amap-android-key

# 环境
ENV=production
