# ================================
# VerveForge .gitignore
# ================================

# Flutter/Dart 相关
.dart_tool/
.packages
.flutter-plugins
.flutter-plugins-dependencies
build/
**/doc/api/
**/ios/Flutter/.last_build_id
.pub-cache/
.pub/

# 代码生成产物
*.g.dart
*.freezed.dart

# iOS 相关
ios/.generated/
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Runner/GeneratedPluginRegistrant.*
ios/Runner/GoogleService-Info.plist
ios/Pods/
ios/.symlinks/
ios/Runner.xcworkspace/xcshareddata/

# Android 相关
android/.gradle/
android/local.properties
android/app/build/
android/app/debug
android/app/profile
android/app/release
android/app/google-services.json
android/app/src/main/res/raw/google-services.json

# 环境变量与密钥
.env
.env.*
!.env.example
!.env.production.example
.supabase/
service_role_key
*.key
*.pem
*.jks
*.keystore
*.p12

# Supabase 本地
supabase/.temp/

# macOS 系统文件
.DS_Store
.AppleDouble
.LSOverride

# 编辑器与 IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws

# 日志与临时文件
*.log
*.tmp
*.bak
*.swp
*~

# Symbolication / Obfuscation
app.*.symbols
app.*.map.json

# 其他
*.class
*.pyc
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/
